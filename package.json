{
  "name": "trx-to-vsplaylist-action",
  "version": "2.0.0",
  "description": "Convert TRX test result files to VS Test playlist files",
  "author": "BenjaminMichaelis",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.js",
    "package:watch": "npx rollup --config rollup.config.js --watch",
    "build": "npm run package",
    "lint": "eslint src/ __tests__/ --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test __tests__/**/*.test.ts",
    "all": "npm run lint && npm run typecheck && npm run test && npm run package"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.1",
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/glob": "^0.7.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.62.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": ">=24"
  }
}
