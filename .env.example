# .env — local action development inputs
# Copy this file to .env (which is gitignored) to run the action locally.
# Note: the post lifecycle (cleanup.js) is NOT executed by local-action;
# it only runs the main entrypoint.
#
# Usage: npx local-action . src/index.js .env
# See: https://github.com/github/local-action

# Required: path or glob to TRX file(s)
INPUT_TRX-FILE-PATH=./TestResults/sample.trx

# Optional: output directory for playlist files
# INPUT_OUTPUT-DIRECTORY=./output

# Optional: test outcomes to include (comma-separated)
# INPUT_TEST-OUTCOMES=Failed

# Optional: artifact name override
# INPUT_ARTIFACT-NAME=my-test-results

# Optional: skip empty playlists
# INPUT_SKIP-EMPTY=true

# Optional: separate playlist per TRX file
# INPUT_SEPARATE=false

# Optional: .NET tool version
# INPUT_TOOL-VERSION=1.3.0

# Optional: .NET SDK channel
# INPUT_DOTNET-VERSION=10.0

# Runner environment — required by @actions/toolkit
RUNNER_TEMP=C:\Temp
RUNNER_TOOL_CACHE=C:\hostedtoolcache
GITHUB_WORKSPACE=.
GITHUB_RUN_ID=1
